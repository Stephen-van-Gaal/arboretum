__pycache__/
*.pyc
*.pyo
.DS_Store
*.egg-info/
dist/
/build/
.venv/
venv/
.env
*.db-journal
.superpowers/

# Session-handoff cache (issue #155). Refreshed on session start by
# .claude/hooks/session-start.sh and by the /handoff skill. Safe to
# delete — will be regenerated from GitHub on the next refresh.
.arboretum/next-cache.json
.arboretum/next-cache.json.tmp
.arboretum/next-cache.err
.arboretum/roadmap-pulse.json
.arboretum/roadmap-pulse.json.tmp
.arboretum/update-cache.json
.arboretum/update-cache.json.tmp

# Local customer-validation generated copies. These are prepared from sibling
# customer checkouts and must never be tracked.
.arboretum/customer-testbeds/

# Session-handoff transient markers (issue #251).
.arboretum/handoff-done
.arboretum/handoff-nudged
.arboretum/handoff-pending.json

# Agent-target task briefs (WS2 of #295). Session artifacts written by
# /start when an issue is triaged as agent-target. Not source.
.arboretum/agent-briefs/

# Additional runtime caches under .arboretum/ — same posture as the
# already-ignored next-cache/handoff-* files: regenerated by scripts/skills,
# safe to delete, not source-of-truth.
.arboretum/active-stage-cache.json
.arboretum/log-comments-cache.json
.arboretum/workspace-cache.json
.arboretum/workspace-cache.json.*

# Per-PR /land run-state (comments ledger, fix ledger) — regenerable, gitignored
.arboretum/land/

# Staged local plugin copy built by .claude/hooks/web-setup.sh on web/dogfood
# session start — a real-file snapshot of skills/ + hooks/ that is installed as
# the arboretum plugin so web sessions load the in-repo dev skills. Runtime
# only, rebuilt every boot; never source.
.arboretum/web-plugin/

# Runtime lock files and worktree storage. Lock files are session-scoped;
# worktrees are git-managed alternate working trees that should never be
# tracked as ordinary files. Both the legacy `.claude/worktrees/` location
# and the top-level `.worktrees/<branch>` convention (per the worktree
# naming rule in CLAUDE.md) are ignored.
.claude/scheduled_tasks.lock
.claude/worktrees/
.worktrees/

# Sibling agent-tool working directories. AGENTS.md is the vendor-neutral
# guidance file checked in; per-tool hooks, skills, and worktree caches stay
# local. The Codex marketplace file is tracked because it is part of the
# arboretum plugin distribution.
.agents/*
!.agents/plugins/
!.agents/plugins/marketplace.json
.claire/
.codex/
