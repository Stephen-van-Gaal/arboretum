#!/usr/bin/env bash
# owner: arboretum-as-plugin
# arboretum — CLI entry point for the arboretum framework
#
# Usage:
#   arboretum bootstrap <target-directory> [project-name]
#   arboretum update
#
# Dispatches to the appropriate script in scripts/.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(realpath "$SCRIPT_DIR/..")"

usage() {
  echo "Usage: arboretum <command> [args...]"
  echo ""
  echo "Commands:"
  echo "  bootstrap <target-dir> [project-name]   Create a new spec-driven project"
  echo "  update                                   Update arboretum files in current project"
  echo ""
  echo "Examples:"
  echo "  arboretum bootstrap ~/Projects/rule-flow"
  echo "  cd ~/Projects/rule-flow && arboretum update"
  exit 1
}

if [ $# -lt 1 ]; then
  usage
fi

COMMAND="$1"
shift

is_arboretum_project() {
  [ -f ".arboretum.yml" ] || [ -f "roadmap.config.yaml" ]
}

case "$COMMAND" in
  bootstrap)
    exec "$REPO_ROOT/scripts/bootstrap-project.sh" "$@"
    ;;
  update)
    # Deploy framework evolution into an existing project (no-session path).
    # Conflicts are reported and skipped here — the /upgrade skill handles
    # interactive conflict resolution.
    if ! is_arboretum_project; then
      echo "arboretum update: not an arboretum project (no .arboretum.yml or roadmap.config.yaml in $(pwd))" >&2
      exit 2
    fi
    exec bash "$REPO_ROOT/scripts/upgrade-sync.sh" --apply
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    echo "Error: unknown command '$COMMAND'"
    echo ""
    usage
    ;;
esac
