{
  "permissions": {
    "allow": [
      "Bash(bash scripts/health-check.sh *)",
      "Bash(bash scripts/generate-register.sh *)",
      "Bash(bash scripts/validate-cross-refs.sh *)",
      "Bash(git status *)",
      "Bash(git rev-parse *)",
      "Bash(git merge-base *)",
      "Bash(git branch --merged *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-commit-branch-check.sh"
          }
        ]
      }
    ]
  }
}
