{
  "permissions": {
    "allow": [
      "Bash(bash scripts/health-check.sh *)",
      "Bash(bash scripts/generate-register.sh *)",
      "Bash(bash scripts/validate-cross-refs.sh *)",
      "Bash(bash scripts/log-stage.sh *)",
      "Bash(bash scripts/cleanup-merged-session.sh *)",
      "Bash(bash scripts/resolve-workflow-slot.sh *)",
      "Bash(bash scripts/refresh-stage-cache.sh *)",
      "Bash(bash scripts/parse-plan-checkboxes.sh *)",
      "Bash(bash scripts/read-s2-frontmatter.sh *)",
      "Bash(bash scripts/read-test-config.sh *)",
      "Bash(bash scripts/write-escape-hatch.sh *)",
      "Bash(git status *)",
      "Bash(git rev-parse *)",
      "Bash(git merge-base *)",
      "Bash(git branch --merged *)",
      "Bash(bash scripts/refresh-workspace-cache.sh *)",
      "Bash(git fetch *)",
      "Bash(git for-each-ref *)",
      "Bash(git worktree list *)",
      "Bash(git rev-list *)",
      "Bash(git symbolic-ref *)",
      "Bash(git remote get-url *)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/statusline.sh"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/web-setup.sh",
            "timeout": 180
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-start.sh"
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/web-setup.sh",
            "timeout": 180
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-commit-branch-check.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/worktree-write-guard.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/prompt-timestamp.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
